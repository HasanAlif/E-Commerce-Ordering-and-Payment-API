{
  "name": "ecommerce-api",
  "version": "1.0.0",
  "description": "E-commerce Ordering & Payment System API (Stripe + bKash)",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "build": "tsc",
    "dev": "node --watch --import tsx/esm src/server.ts",
    "lint": "eslint ./src/**/*.{ts,tsx}",
    "generate:prisma": "prisma generate",
    "generate": "tsx src/generate-module.ts",
    "migrate": "prisma migrate dev",
    "studio": "prisma studio",
    "push": "prisma db push",
    "pull": "prisma db pull",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules --dns-result-order=ipv4first\" jest",
    "test:coverage": "NODE_OPTIONS=\"--experimental-vm-modules --dns-result-order=ipv4first\" jest --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.4.2",
    "axios": "1.18.1",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.5.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "8.5.2",
    "google-auth-library": "^9.14.2",
    "helmet": "8.2.0",
    "http-status": "^1.7.4",
    "ioredis": "5.11.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.16",
    "pg": "^8.20.0",
    "streamifier": "^0.1.1",
    "stripe": "22.3.1",
    "swagger-jsdoc": "6.3.0",
    "swagger-ui-express": "5.0.1",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^25.4.0",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.18.0",
    "@types/streamifier": "^0.1.2",
    "@types/supertest": "7.2.0",
    "@types/swagger-jsdoc": "6.0.4",
    "@types/swagger-ui-express": "4.1.8",
    "@types/uuid": "^10.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.3",
    "globals": "^17.7.0",
    "jest": "29.7.0",
    "jest-environment-node-single-context": "^29.4.0",
    "prisma": "^7.4.2",
    "supertest": "7.2.2",
    "ts-jest": "29.4.11",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
