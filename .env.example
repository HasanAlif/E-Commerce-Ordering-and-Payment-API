# Server Configuration
NODE_ENV=development
PORT=8080
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
WEBSITE_NAME=E-Commerce
CONTACT_MAIL=contact@example.com
DEFAULT_CURRENCY=usd

# Database (Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/ecommerce?schema=public

# Redis
REDIS_URL=redis://localhost:6379
CATEGORY_TREE_TTL=3600

# Authentication (JWT)
JWT_SECRET=your_jwt_secret_key_here
EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRES_IN=30d
RESET_PASS_TOKEN=your_reset_pass_token_here
RESET_PASS_TOKEN_EXPIRES_IN=1h
RESET_PASS_LINK=http://localhost:3000/reset-password
BCRYPT_SALT_ROUNDS=12

# Admin Seed
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=adminpassword

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8080/api/auth/google/callback

# Email Configuration (Nodemailer)
MAIL_EMAIL=your_email@gmail.com
MAIL_APP_PASS=your_app_password

# Stripe Payment
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_CURRENCY=usd

# bKash Payment
BKASH_ENABLED=false
BKASH_BASE_URL=https://checkout.sandbox.bka.sh/v1.2.0-beta
BKASH_APP_KEY=your_bkash_app_key
BKASH_APP_SECRET=your_bkash_app_secret
BKASH_USERNAME=your_bkash_username
BKASH_PASSWORD=your_bkash_password
BKASH_CALLBACK_URL=http://localhost:3000/payment/bkash/callback

# File Upload (Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# File Upload (DigitalOcean Spaces / S3 compatible)
DO_SPACE_ENDPOINT=nyc3.digitaloceanspaces.com
DO_SPACE_BUCKET=your_bucket_name
DO_SPACE_ACCESS_KEY=your_do_space_access_key
DO_SPACE_SECRET_KEY=your_do_space_secret_key
